model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  avatarUrl String?
  role      UserRole
  status    UserStatus @default(ACTIVE)

  properties    Property[]
  payment       Payment[]
  reviews       Review[]
  rentalRequest RentalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
